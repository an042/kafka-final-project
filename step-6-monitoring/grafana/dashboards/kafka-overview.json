{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Дашборд мониторинга Kafka кластера — маркетплейс 'Покупай выгодно'",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Состояние кластера",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"color": "red", "index": 0, "text": "DOWN"}}, "type": "value"},
            {"options": {"1": {"color": "green", "index": 1, "text": "UP"}}, "type": "value"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "none", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
          "expr": "up{job=\"kafka\", broker=\"kafka-1\"}",
          "legendFormat": "kafka-1"
        }
      ],
      "title": "Брокер kafka-1",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"color": "red", "index": 0, "text": "DOWN"}}, "type": "value"},
            {"options": {"1": {"color": "green", "index": 1, "text": "UP"}}, "type": "value"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "id": 3,
      "options": {"colorMode": "background", "graphMode": "none", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
          "expr": "up{job=\"kafka\", broker=\"kafka-2\"}",
          "legendFormat": "kafka-2"
        }
      ],
      "title": "Брокер kafka-2",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"color": "red", "index": 0, "text": "DOWN"}}, "type": "value"},
            {"options": {"1": {"color": "green", "index": 1, "text": "UP"}}, "type": "value"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "id": 4,
      "options": {"colorMode": "background", "graphMode": "none", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
          "expr": "up{job=\"kafka\", broker=\"kafka-3\"}",
          "legendFormat": "kafka-3"
        }
      ],
      "title": "Брокер kafka-3",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "id": 5,
      "options": {"colorMode": "background", "graphMode": "none", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
          "expr": "sum(kafka_server_replicamanager_underreplicatedpartitions{job=\"kafka\"})",
          "legendFormat": "Под-реплицированных"
        }
      ],
      "title": "Под-реплицированные партиции",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 10,
      "title": "Пропускная способность",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "сообщений/сек",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "ops"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "id": 11,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
          "expr": "sum by(topic) (rate(kafka_server_brokertopicmetrics_MessagesinPerSec_OneMinuteRate{job=\"kafka\"}[1m]))",
          "legendFormat": "{{topic}}"
        }
      ],
      "title": "Входящие сообщения по топикам (сообщений/сек)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "байт/сек",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "Bps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "id": 12,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
          "expr": "sum by(broker) (rate(kafka_server_brokertopicmetrics_BytesInPerSec_OneMinuteRate{job=\"kafka\"}[1m]))",
          "legendFormat": "{{broker}}"
        }
      ],
      "title": "Входящий трафик по брокерам (байт/сек)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "id": 20,
      "title": "Consumer Group Lag",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 100},
              {"color": "red", "value": 1000}
            ]
          }
        }
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 15},
      "id": 21,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
          "expr": "sum by(group, topic) (kafka_consumer_group_lag{job=\"kafka\"})",
          "legendFormat": "{{group}} / {{topic}}"
        }
      ],
      "title": "Отставание consumer групп",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["kafka", "покупай-выгодно"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Kafka — Покупай выгодно",
  "uid": "kafka-overview",
  "version": 1
}
